<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config
  - Production HTTPS traffic is always allowed.
  - Cleartext HTTP is permitted ONLY for development IPs:
      10.0.2.2   → Android emulator host machine
      10.0.3.2   → Genymotion host machine
      192.168.x.x → common local network range
  - In production, set API_URL to your HTTPS server URL via --dart-define.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Allow HTTP only for local development servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
