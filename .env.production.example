# Copy this to .env and fill in real values before deploying.
# NEVER commit .env to git.

# Database
DB_PASSWORD=your_strong_db_password_here

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_32plus_char_random_string
JWT_REFRESH_SECRET=replace_with_different_32plus_char_random_string

# CORS — set to your actual domain (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# SMTP (use SendGrid / Gmail App Password / etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
