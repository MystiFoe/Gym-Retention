# ============================================================================
# ENVIRONMENT VARIABLES - GYM RETENTION MVP
# ============================================================================

# NODE ENVIRONMENT
NODE_ENV=development
PORT=3000

# DATABASE
DATABASE_URL=postgresql://gym_user:change_me_here@localhost:5432/gym_retention
DATABASE_POOL_SIZE=20
DB_HOST=localhost
DB_NAME=gym_retention
DB_USER=gym_user
DB_PASSWORD=change_me_here

# JWT SECRETS (Generate with: openssl rand -base64 32)
JWT_SECRET=your_strong_secret_key_minimum_32_characters_here
JWT_REFRESH_SECRET=your_strong_refresh_key_minimum_32_characters_here

# CORS
CORS_ORIGIN=http://localhost:3000

# EMAIL (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@gymretention.com

# LOGGING
LOG_LEVEL=info

# REDIS (Optional for caching)
REDIS_URL=redis://localhost:6379

# BACKUP
BACKUP_PATH=/backups

# DOCKER VARIABLES
DOCKER_COMPOSE_PROJECT=gym_retention
DB_ROOT_PASSWORD=root_password_change_me

